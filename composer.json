{
    "name": "team-nifty-gmbh/shopware-sdk",
    "description": "PHP SDK for the Shopware 6 Admin API, built with Saloon",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "saloonphp/pagination-plugin": "^2.0",
        "saloonphp/saloon": "^3.0",
        "spatie/laravel-data": "^3.0|^4.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "pestphp/pest": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "TeamNiftyGmbH\\Shopware\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TeamNiftyGmbH\\Shopware\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "lint": "vendor/bin/pint --test",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
